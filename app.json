{
  "expo": {
    "name": "AlumiEye",
    "slug": "eyeapp-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "alumieye",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "vn.blockchain.alumieye",
      "supportsTablet": true
    },
    "android": {
      "package": "vn.blockchain.alumieye",
      "adaptiveIcon": {
        "backgroundColor": "#E8E3D9",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      "expo-secure-store",
      "expo-font"
    ]
  }
}
