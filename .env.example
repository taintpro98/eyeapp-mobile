# Copy this file to .env and fill in your values
# EXPO_PUBLIC_* vars are inlined at build time by Metro — no secrets here

# Backend domain (no trailing slash, no version path)
#
# Real Android device (localhost does NOT work on physical devices):
#   EXPO_PUBLIC_API_URL=https://eyeapp-backend.fly.dev
#
# Android emulator (routes host machine via 10.0.2.2):
#   EXPO_PUBLIC_API_URL=http://10.0.2.2:8080
#
# iOS Simulator / local dev:
#   EXPO_PUBLIC_API_URL=http://localhost:8080
EXPO_PUBLIC_API_URL=https://eyeapp-backend.fly.dev
